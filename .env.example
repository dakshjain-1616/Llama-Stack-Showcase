# ============================================================================
# LLM Provider Configuration
# ----------------------------------------------------------------------------
# This project speaks the OpenAI-compatible chat-completions API, so any
# provider that exposes that surface works. Pick ONE of the options below.
# ============================================================================

# --- Option A: OpenRouter (recommended; Llama 4 Scout + 200+ other models) ---
# Get your API key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here
# Override the model if you want something other than Llama 4 Scout:
# OPENROUTER_MODEL=meta-llama/llama-4-scout
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Option B: Together AI (original Llama Stack provider) ---
# Get your API key from: https://api.together.xyz/settings/api-keys
# TOGETHER_API_KEY=your_together_api_key_here
# LLAMA_STACK_ENDPOINT=https://api.together.xyz/v1

# --- Default model (used if OPENROUTER_MODEL is unset) ---
DEFAULT_MODEL=meta-llama/Llama-4-Scout-17B-16E-Instruct
